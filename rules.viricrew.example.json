{
  "schemaVersion": 2,
  "rules": [
    { "category": "ViriCrew backend", "process": "viricrew" },
    { "category": "ViriCrew Desktop", "process": "viricrew-desktop", "ownerRoot": true, "ownerLabel": "ViriCrew Desktop" },
    { "category": "Cass", "process": "cass" },
    { "category": "ViriVox", "process": "ViriVox", "criticality": "important", "recommendationPolicy": "modelResident", "minimumIdleMinutes": 0 },
    { "category": "Jarvis", "process": "jarvis-orb" },
    { "category": "Vertex MCP", "textContainsAny": ["vertex-mcp"] },
    { "category": "ViriCrew MCP", "process": "node", "textRegex": "viricrew[\\\\/]dist[\\\\/]index\\.js" },
    { "category": "Circuit Studio", "textContainsAny": ["circuit-studio"] },
    { "category": "Claude reflection", "commandContainsAll": ["cm.ts", "reflect"] },
    { "category": "Deploy MCP", "textContainsAny": ["mcp-deploy", "breezedeploy-mcp"] },
    { "category": "Suno", "textRegex": "Projects[\\\\/]suno" },
    { "category": "Orchestrator", "commandContainsAll": ["orchestrator", "orc.mjs"] },
    { "category": "Realtime voice", "textContainsAny": ["realtime-voice"] }
  ]
}
